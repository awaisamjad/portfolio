---
interface Props {
  date: Date;
}

const { date } = Astro.props;
---

<time
  datetime={(function () {
    try {
      return date ? date.toISOString() : '';
    } catch (e) {
      return date ? date.toString() : '';
    }
  })()}
>
  {
    date
      ? (typeof date === "string"
        ? date
        : date.toLocaleDateString("en-GB", {
            day: "numeric",
            month: "short",
            year: "numeric",
            timeZone: "Europe/London"
          }))
      : 'Invalid date'
  }
</time>
